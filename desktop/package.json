{
  "name": "f1-replay-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.mcurmi05.f1replay",
    "productName": "F1 Replay",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["main.js", "preload.js"],
    "extraResources": [
      {
        "from": "../server/dist_app/f1-replay",
        "to": "server"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
