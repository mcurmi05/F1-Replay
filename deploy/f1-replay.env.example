# uvicorn binds here; Caddy reverse-proxies to it. Keep it on loopback so the
# app is never exposed directly on the public interface.
HOST=127.0.0.1
PORT=8000

# Headless server: do not try to open a browser on startup.
F1_NO_BROWSER=1

# Admin secret. The /admin console and the F1TV auth-mutating API endpoints
# require this value in the X-Admin-Token header. Generate a long random string,
# for example: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-long-random-string

# Persistent cache directory for FastF1 data and live track geometry. Must be
# writable by the service user and survive restarts.
FASTF1_CACHE_DIR=/var/lib/f1-replay/cache

# Public origin. Same-origin in production so CORS is unused, but set it anyway.
CORS_ORIGINS=https://f1.example.com
