# Copy to .env before running docker compose. All values have working defaults
# baked into the image, so the only one you usually set is ADMIN_TOKEN.

# Admin secret. Required to open /admin and set the shared F1TV token. Generate
# a long random string, e.g. openssl rand -hex 32. Leave unset on a private
# single-user instance to keep the normal in-app sign-in flow open.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Public origin(s) allowed for CORS, comma separated. Same-origin in this setup
# so it is unused, but set it to your public URL for a hosted deployment.
CORS_ORIGINS=http://localhost:8000

# Cap for the FastF1 cache in gigabytes (used by the optional prune job). The
# in-container cache lives on the f1-cache volume at /data/cache.
CACHE_MAX_GB=30
