# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# In Vite, ONLY variables prefixed with VITE_ are exposed to your app
# (via import.meta.env.VITE_*). Anything VITE_-prefixed gets bundled into
# the client and is visible in the browser, so never put a truly secret
# key here. For secrets, proxy requests through a backend instead.

# Base URL for the F1 data source you end up using
VITE_API_BASE_URL=https://api.example.com

# Optional API key, only if your data provider requires one.
# Remember: this ships to the browser, so it is only safe for
# public / rate-limited keys.
VITE_API_KEY=your-api-key-here
